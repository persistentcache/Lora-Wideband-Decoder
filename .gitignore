# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# IQ data (large)
*.sc16
*.cf32
*.fc32
captures/
recordings/

# Test data / runtime logs
*.jsonl
*.log
*.npz

# --debug / collect_debug.py output (users run these to file issues)
lora_debug_*.txt

# User-specific runtime config + autosaved data
web_settings.json
lora_web/web_settings.json
lora_web/lora_autosave.jsonl
lora_web/lora_unknown.jsonl
lora_web/lora_packets.jsonl
lora_web/dec_pkts.jsonl
# Rotated / disabled runtime logs — the *.jsonl rule above misses suffixed
# variants like lora_unknown.jsonl.off, which slipped in once.
*.jsonl.*

# Secrets
*.key
*.pem
keys.json
keystore.json
# Per-node identity keys (Ed25519 / X25519 scalars for DM decrypt) — NEVER
# commit; each operator generates their own via the Keys panel.
lora_web/lora_keys.json
lora_keys.json

# Local env-var overrides (reference: docs/env-overrides.md)
.env
.env.local

# Personal / scratch tooling
tools/

# Local agent config
.claude/

# Old baselines / build artifacts
archive/


# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Per-deployment classifier state — built from each user's own Meshtastic traffic.
# Should not be shipped — each user's system bootstraps to their own hardware.
# Listed by bare name (no dir prefix) so they're ignored wherever the process cwd
# drops them — lora_web/ when run from the repo root, src/web/ otherwise (the
# src/web/ copy is exactly what leaked in once).
lwbd_model.pkl
lora_node_profiles.json
lora_device_clusters.json
