# LoRa wideband receiver — environment-variable overrides.
#
# These knobs apply on top of lora.toml.  ALL lines are commented out by
# default: copy this file to `.env` and uncomment the lines you want, or
# export them in your shell before launching lora_web.py / lora_detect.py.
#
# Anything set here overrides the matching TOML key.  Most users never need
# to touch this file — defaults are tuned for plug-and-play.
#
# Loading: lora_web.py and lora_detect.py do NOT auto-load .env; either
# `export` the vars in your shell, or prefix the launch command, e.g.:
#   LORA_DECODE_WORKERS=8 python3 lora_web/lora_web.py


# ============================================================================
# Config file location
# ============================================================================
# LORA_CONFIG=/path/to/lora.toml   # Override the default lora.toml lookup.


# ============================================================================
# Decode pipeline
# ============================================================================

# Decode worker count.  -1 / unset = auto-scale from cpu_count
# (max(2, min(16, ncpu-6))).  Set to a positive integer to pin.
# LORA_DECODE_WORKERS=8

# Per-capture fast-pass budget (seconds).  Captures that bail are re-queued
# to the slow pass.  Raise if SF11/12 packets are bailing with [BUDGET].
# LORA_DECODE_BUDGET_S=10.0

# Slow-pass budget (seconds) for re-decoded stragglers.  Default 45 s.
# LORA_SLOW_BUDGET_S=45

# Detect-pool commit lag — lower = lower latency, higher = more stable
# on slow disks / busy hosts.  Default 4.
# LORA_COMMIT_LAG=4

# Capture oversampling factor.  8 = 2 MHz at SF7/BW250 (default).  Lower
# (4 = 4 MHz) → faster decode, less fingerprint resolution.  Higher (16 =
# 1 MHz) → highest fingerprint resolution, slowest decode.
# LORA_EXPORT_DEC=8

# How many duplicate captures to keep per (carrier, RF-second).  Default 2
# (best-capture selection).  Set 1 for lean live (decode each packet ONCE).
# LORA_DEDUP_KEEP=2

# Internal FFT thread count.  Default = scipy's `workers=-1` (all cores).
# Pin lower on shared hosts to leave cores for other tasks.
# LORA_FFT_WORKERS=4


# ============================================================================
# Detection sensitivity
# ============================================================================

# Max-hold detection (low-SNR booster).  1 = on (default), 0 = off.
# Disable on very weak hosts to reduce false candidates the decoder has to
# confirm.  Cost: misses some weak distant packets.
# LORA_MAXHOLD=1


# ============================================================================
# Protocol parsing
# ============================================================================

# Comma-separated list of enabled protocols (default: all enabled).
# Available: meshtastic, meshcore, lorawan, loramesher, lora_aprs,
# reticulum, disaster_radio, ebyte_lora, radiohead
# Disabling unused protocols saves CPU on the decoder's parser dispatch.
# Normally controlled via the Web UI's Advanced Options.
# LORA_PROTOCOLS=meshtastic,meshcore,lorawan

# Surface unknown-protocol frames (unparsed but valid-looking LoRa).
# 1 = on, 0 = off (default).  Normally toggled via Web UI.
# LORA_UNKNOWN=0

# LoRaWAN region — affects channel-grid verification.  Default US915.
# Values: US915, EU868, AS923, AU915, IN865, CN470, KR920.
# LORA_REGION=US915

# LoRaWAN channel-grid tolerance (kHz).  Default 60.  Raise on hosts with
# poor TCXO discipline if real LoRaWAN frames are being rejected as off-grid.
# LORA_GRID_TOL_KHZ=60

# MeshCore channel pre-shared keys (comma-separated hex/base64 list).
# Lets the parser decrypt MeshCore channel traffic you have keys for.
# LORA_MC_CHANNEL_KEYS=


# ============================================================================
# File paths (advanced — usually controlled by lora_web automatically)
# ============================================================================

# Packet log location (web UI tails this file).
# LORA_PKT_LOG=/tmp/lora_packets.jsonl

# Multi-key file (Meshtastic PSK list, one key per line).
# LORA_KEYS=/tmp/lora_keys.txt

# Waterfall PSD shared frame file.
# LORA_PSD_FILE=/dev/shm/lora_psd.bin

# Waterfall framerate (frames/sec) the gate writes.  Default 10.
# LORA_PSD_FPS=10

# Unknown-protocol detail log.
# LORA_UNKNOWN_REPORT=/tmp/lora_unknown.jsonl


# ============================================================================
# Debug / diagnostics (rarely needed)
# ============================================================================

# Force the detect pool to serial mode (single-process gate, easier to
# attach a profiler).  Default: parallel.
# LORA_DETECT_SERIAL=1

# SFD CFO refinement debug output.  Verbose.
# LORA_SFD_DEBUG=1

# Stub-mode detection (test harness use only).
# LORA_STUB_DETECT=1

# Full-spectrum scan mode flag.
# LORA_SCAN_FULL=1
